{
  "name": "sign2sign",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo export --platform web --output-dir dist",
    "web:dev": "expo start --web",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run web && electron-builder build",
    "electron:build:mac": "npm run web && electron-builder build --mac",
    "electron:build:win": "npm run web && electron-builder build --win",
    "verify:electron": "node --check electron/main.js && node --check build/afterPack.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@supabase/supabase-js": "^2.99.2",
    "electron-updater": "^6.8.3",
    "expo": "~55.0.7",
    "expo-auth-session": "~55.0.9",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-location": "~55.1.4",
    "expo-network": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
