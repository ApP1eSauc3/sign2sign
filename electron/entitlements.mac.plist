<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- V8's JIT needs to map executable memory. allow-jit is the narrow,
         MAP_JIT-scoped entitlement; we intentionally drop the broader
         allow-unsigned-executable-memory. If the NOTARIZED app fails to launch,
         re-add com.apple.security.cs.allow-unsigned-executable-memory as a
         fallback — this is the first thing to check after a signed build. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
  </dict>
</plist>
